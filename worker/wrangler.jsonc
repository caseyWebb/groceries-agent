{
  // grocery-mcp — custom MCP server for the grocery agent.
  // Stateless (createMcpHandler over Streamable HTTP): no Durable Objects, no KV.
  // Secrets are NOT in this file. Set them out-of-band and they persist across deploys:
  //   wrangler secret put GITHUB_TOKEN
  // Non-secret config (public repo coordinates) lives in vars below.
  "name": "grocery-mcp",
  "main": "src/index.ts",
  // The Worker is reached only through the Cloudflare Access-gated custom domain.
  // Disable the raw *.workers.dev route so there is no un-gated way in.
  "workers_dev": false,
  "compatibility_date": "2025-06-01",
  // Required by the `agents` SDK internals (mimetext / node:diagnostics_channel).
  // Our own parsing (js-yaml + smol-toml) is workerd-safe and does not depend on it.
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "GITHUB_OWNER": "caseyWebb",
    "GITHUB_REPO": "groceries",
    "GITHUB_REF": "main",
    // Cloudflare Access (non-secret). In-Worker JWT validation activates only when
    // BOTH are set; ACCESS_TEAM_DOMAIN stays blank until the Zero Trust team domain
    // (e.g. "casey.cloudflareaccess.com") is filled in, then enforcement turns on.
    "ACCESS_AUD": "bd70d44841bf62d25e53280251f1f5b2f8dc7131057bca9d3f54128b56f9985c",
    "ACCESS_TEAM_DOMAIN": "dirtbags.cloudflareaccess.com"
  },
  "observability": {
    "enabled": true
  }
}
